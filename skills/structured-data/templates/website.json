{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "<SITE_URL>/#website",
  "name": "<SITE_NAME>",
  "url": "<SITE_URL>",
  "description": "<ONE_SENTENCE_DESCRIPTION>",
  "inLanguage": "en",
  "publisher": {
    "@id": "<SITE_URL>/#organization"
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "<SITE_URL>/search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}
